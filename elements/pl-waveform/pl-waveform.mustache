{{#question}}
<div class="pl-waveform"
     id="pl-waveform-{{uuid}}"
     data-panel="question"
     data-input-mode="{{input_mode}}"
     data-editable-signals="{{editable_signals_json}}"
     data-parse-errors="{{parse_errors_json}}"
     data-parse-error-cells="{{parse_error_cells_json}}"
     data-feedback="{{feedback}}"
     {{#has_cell_scores}}data-cell-scores="{{cell_scores_json}}"{{/has_cell_scores}}>
    <script type="WaveDrom">
    {{{wavedrom_json}}}
    </script>
    {{#has_editable}}
    <script type="application/json" class="pl-waveform-editable-rows">
    {{{editable_row_models_json}}}
    </script>
    {{/has_editable}}
    {{#has_editable}}
    <div class="pl-waveform-editor-layer"></div>
    {{/has_editable}}
    {{#has_editable}}
    {{#editable_rows}}
    {{#cells}}
    {{#toggle_mode}}
    <input type="hidden"
           name="{{key}}"
           id="pl-wf-hidden-{{key}}"
           value="{{toggle_value}}"
           {{^editable}}disabled{{/editable}} />
    {{/toggle_mode}}
    {{#text_mode}}
    <input type="text"
           name="{{key}}"
           id="pl-wf-{{key}}"
           class="pl-waveform-question-control pl-waveform-proxy"
           data-key="{{key}}"
           data-signal="{{signal_name}}"
           data-cycle="{{cycle_num}}"
           data-abs-index="{{abs_index}}"
           data-period="{{period}}"
           data-allowed-values="{{allowed_values_json}}"
           data-allowed-values-label="{{allowed_values_label}}"
           {{#has_bus_width}}data-bus-width="{{bus_width}}"{{/has_bus_width}}
           data-input-hint="{{text_input_hint}}"
           aria-label="{{aria_label}}"
           {{#has_raw_value}}value="{{{raw_value}}}"{{/has_raw_value}}
           {{^editable}}disabled{{/editable}}
           placeholder="?"
           maxlength="{{text_input_maxlength}}"
           autocomplete="off"
           data-lpignore="true"
           style="position:absolute;visibility:hidden;"/>
    {{/text_mode}}
    {{/cells}}
    {{/editable_rows}}
    {{/has_editable}}
</div>
{{/question}}
{{#submission}}
<div class="pl-waveform pl-waveform-submission-view"
     id="pl-waveform-sub-{{uuid}}"
     data-panel="submission"
     data-input-mode="{{input_mode}}"
     data-editable-signals="{{editable_signals_json}}"
     data-parse-errors="{{parse_errors_json}}"
     data-parse-error-cells="{{parse_error_cells_json}}"
     data-feedback="{{feedback}}"
     {{#has_cell_scores}}data-cell-scores="{{cell_scores_json}}"{{/has_cell_scores}}>
    <script type="WaveDrom">
    {{{wavedrom_json}}}
    </script>
</div>
{{/submission}}
{{#answer}}
<div class="pl-waveform pl-waveform-answer-view"
     id="pl-waveform-ans-{{uuid}}"
     data-panel="answer"
     data-editable-signals="{{editable_signals_json}}"
     data-diff="{{{diff_json}}}">

    <script type="WaveDrom">
    {{{wavedrom_json}}}
    </script>
</div>
{{/answer}}
